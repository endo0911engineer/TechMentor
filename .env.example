DATABASE_URL=postgresql://devpay:devpay@db:5432/devpay
ADMIN_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
# 本番（HTTPS）環境では true に設定（httpOnly Cookie の Secure フラグ）
COOKIE_SECURE=false
# 本番フロントエンドの Origin（CORS 許可）例: https://example.com
FRONTEND_ORIGIN=

# reCAPTCHA v3（未設定の場合は検証をスキップ＝開発環境向け）
# https://www.google.com/recaptcha/admin で取得
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
